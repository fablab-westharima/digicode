// ===== OTTO Gesture (感情表現) =====

Blockly.Blocks['otto_gesture'] = {
  init: function() {
    this.appendDummyInput()
        .appendField('😊 OTTOジェスチャー')
        .appendField(new Blockly.FieldDropdown([
          ['ハッピー', 'OttoHappy'],
          ['超ハッピー', 'OttoSuperHappy'],
          ['悲しい', 'OttoSad'],
          ['勝利', 'OttoVictory'],
          ['怒り', 'OttoAngry'],
          ['眠い', 'OttoSleeping'],
          ['イライラ', 'OttoFretful'],
          ['ラブ', 'OttoLove'],
          ['困惑', 'OttoConfused'],
          ['おなら', 'OttoFart'],
          ['手を振る', 'OttoWave'],
          ['マジック', 'OttoMagic'],
          ['失敗', 'OttoFail']
        ]), 'GESTURE');
    this.setPreviousStatement(true, null);
    this.setNextStatement(true, null);
    this.setColour(OTTO_COLOR);
    this.setTooltip('OTTOが感情を動きと音で表現します');
  }
};

javascriptGenerator.forBlock['otto_gesture'] = function(block: Blockly.Block) {
  const gesture = block.getFieldValue('GESTURE');
  return `  otto.playGesture(${gesture});\n`;
};

pythonGenerator.forBlock['otto_gesture'] = function(block: Blockly.Block) {
  const gesture = block.getFieldValue('GESTURE');
  // Python版は簡易実装
  const gestureMap: { [key: string]: string } = {
    'OttoHappy': 'happy',
    'OttoSuperHappy': 'super_happy',
    'OttoSad': 'sad',
    'OttoVictory': 'victory',
    'OttoAngry': 'angry',
    'OttoSleeping': 'sleeping',
    'OttoFretful': 'fretful',
    'OttoLove': 'love',
    'OttoConfused': 'confused',
    'OttoFart': 'fart',
    'OttoWave': 'wave',
    'OttoMagic': 'magic',
    'OttoFail': 'fail'
  };
  return `otto.play_gesture("${gestureMap[gesture]}")\n`;
};

