/*
 * DigiCodeOtto Blockly Blocks
 *
 * Blocks for controlling OTTO-compatible bipedal robots.
 * Supports both Arduino C++ and MicroPython.
 */

import * as Blockly from 'blockly';
import { javascriptGenerator } from 'blockly/javascript';
import { pythonGenerator } from 'blockly/python';
import { getOttoPins } from '../utils/pinHelper';

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const generator = javascriptGenerator as any;
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const pyGen = pythonGenerator as any;

const OTTO_COLOR = '#FF6B35';  // Orange color for OTTO blocks

// ===== OTTO Initialization =====

Blockly.Blocks['otto_init'] = {
  init: function() {
    const pins = getOttoPins();
    this.appendDummyInput()
        .appendField('🤖 OTTO初期化')
        .appendField('左足ピン')
        .appendField(new Blockly.FieldNumber(pins.leftLeg, 0, 39), 'PIN_LL')
        .appendField('右足ピン')
        .appendField(new Blockly.FieldNumber(pins.rightLeg, 0, 39), 'PIN_RL')
        .appendField('左足首ピン')
        .appendField(new Blockly.FieldNumber(pins.leftFoot, 0, 39), 'PIN_LF')
        .appendField('右足首ピン')
        .appendField(new Blockly.FieldNumber(pins.rightFoot, 0, 39), 'PIN_RF');
    this.setPreviousStatement(true, null);
    this.setNextStatement(true, null);
    this.setColour(OTTO_COLOR);
    this.setTooltip('OTTOロボットを初期化します（ピン番号はプリセットから取得）');
  }
};

javascriptGenerator.forBlock['otto_init'] = function(block: Blockly.Block) {
  const pinLL = block.getFieldValue('PIN_LL');
  const pinRL = block.getFieldValue('PIN_RL');
  const pinLF = block.getFieldValue('PIN_LF');
  const pinRF = block.getFieldValue('PIN_RF');

  generator.definitions_['include_otto'] = '#include <DigiCodeOtto.h>';
  generator.definitions_['otto_instance'] = 'DigiCodeOtto otto;';

  return `  otto.init(${pinLL}, ${pinRL}, ${pinLF}, ${pinRF});\n`;
};

pythonGenerator.forBlock['otto_init'] = function(block: Blockly.Block) {
  const pinLL = block.getFieldValue('PIN_LL');
  const pinRL = block.getFieldValue('PIN_RL');
  const pinLF = block.getFieldValue('PIN_LF');
  const pinRF = block.getFieldValue('PIN_RF');

  pyGen.definitions_['import_otto'] = 'from digicode_otto import DigiCodeOtto';
  pyGen.definitions_['otto_instance'] = 'otto = DigiCodeOtto()';

  return `otto.init(${pinLL}, ${pinRL}, ${pinLF}, ${pinRF})\n`;
};

// ===== OTTO Home Position =====

Blockly.Blocks['otto_home'] = {
  init: function() {
    this.appendDummyInput()
        .appendField('🏠 OTTOホームポジション');
    this.setPreviousStatement(true, null);
    this.setNextStatement(true, null);
    this.setColour(OTTO_COLOR);
    this.setTooltip('OTTOを直立姿勢にします');
  }
};

javascriptGenerator.forBlock['otto_home'] = function() {
  return `  otto.home();\n`;
};

pythonGenerator.forBlock['otto_home'] = function() {
  return `otto.home()\n`;
};

// ===== OTTO Walk =====

Blockly.Blocks['otto_walk'] = {
  init: function() {
    this.appendDummyInput()
        .appendField('🚶 OTTO歩く')
        .appendField(new Blockly.FieldNumber(2, 1, 10), 'STEPS')
        .appendField('歩')
        .appendField(new Blockly.FieldDropdown([
          ['前進', '1'],
          ['後退', '-1']
        ]), 'DIRECTION')
        .appendField('速度')
        .appendField(new Blockly.FieldDropdown([
          ['普通', '1000'],
          ['速い', '600'],
          ['遅い', '1500']
        ]), 'SPEED');
    this.setPreviousStatement(true, null);
    this.setNextStatement(true, null);
    this.setColour(OTTO_COLOR);
    this.setTooltip('OTTOを歩かせます');
  }
};

javascriptGenerator.forBlock['otto_walk'] = function(block: Blockly.Block) {
  const steps = block.getFieldValue('STEPS');
  const direction = block.getFieldValue('DIRECTION');
  const speed = block.getFieldValue('SPEED');

  return `  otto.walk(${steps}, ${speed}, ${direction});\n`;
};

pythonGenerator.forBlock['otto_walk'] = function(block: Blockly.Block) {
  const steps = block.getFieldValue('STEPS');
  const direction = block.getFieldValue('DIRECTION');
  const speed = block.getFieldValue('SPEED');

  return `otto.walk(${steps}, ${speed}, ${direction})\n`;
};

