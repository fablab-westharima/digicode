// ===== OTTO Bend =====

Blockly.Blocks['otto_bend'] = {
  init: function() {
    this.appendDummyInput()
        .appendField('↔️ OTTO傾ける')
        .appendField(new Blockly.FieldDropdown([
          ['左', 'left'],
          ['右', 'right']
        ]), 'DIRECTION')
        .appendField(new Blockly.FieldNumber(1, 1, 5), 'STEPS')
        .appendField('回');
    this.setPreviousStatement(true, null);
    this.setNextStatement(true, null);
    this.setColour(OTTO_COLOR);
    this.setTooltip('OTTOを左右に傾けます');
  }
};

javascriptGenerator.forBlock['otto_bend'] = function(block: Blockly.Block) {
  const direction = block.getFieldValue('DIRECTION');
  const steps = block.getFieldValue('STEPS');

  if (direction === 'left') {
    return `  otto.bendLeft(${steps}, 1000);\n`;
  } else {
    return `  otto.bendRight(${steps}, 1000);\n`;
  }
};

pythonGenerator.forBlock['otto_bend'] = function(block: Blockly.Block) {
  const direction = block.getFieldValue('DIRECTION');
  const steps = block.getFieldValue('STEPS');

  if (direction === 'left') {
    return `otto.bend_left(${steps}, 1000)\n`;
  } else {
    return `otto.bend_right(${steps}, 1000)\n`;
  }
};

